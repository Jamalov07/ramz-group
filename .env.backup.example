# ─── Database Backup ─────────────────────────────────────────────────────────
# Bu fayl ixtiyoriy. Asosiy .env dagi DB_* o'zgaruvchilari backup scriptlari
# tomonidan ham ishlatiladi. Quyidagi qiymatlarni .env ga qo'shishingiz mumkin.

# Lokal backup papkasi (default: loyiha/backups)
# BACKUP_DIR=/var/backups/ramz-group

# Lokal backup saqlash muddati (kun)
RETENTION_DAYS=7

# rclone remote va papka (Google Drive)
# rclone config orqali "gdrive" remote yarating
RCLONE_REMOTE=gdrive:ramz-group/backups
RCLONE_ENABLED=true

# Docker Compose servis nomlari
# DB_SERVICE=db
# APP_SERVICE=app

# Cron vaqti (install-backup-cron.sh uchun, default: har kuni 02:00)
# CRON_SCHEDULE=0 2 * * *
# CRON_LOG=/var/log/ramz-backup.log
